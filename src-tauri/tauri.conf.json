{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "İmzamatik",
  "version": "0.1.12",
  "identifier": "io.mersel.dss.agent.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "İmzamatik",
        "width": 1180,
        "height": 780,
        "minWidth": 940,
        "minHeight": 640,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 16 },
        "transparent": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/jre": "jre",
      "resources/jre21": "jre21",
      "resources/services": "services"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mersel-dss/mersel-dss-agent-desktop-app/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdFNzhCREZDRjE1NTQyMgpSV1FpVkJYUDM0dm5CMUVSaGVtaWJUMDRXTFZmOFdLM1MrUDFxa3AwdThDVlRaUjg0aVBaT0RGOQo="
    }
  }
}
