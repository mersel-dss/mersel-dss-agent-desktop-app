# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Servis manifesti workflow'unun ürettiği Pages çıktısı (CI'da üretilir)
_site

# Paketlenmiş JRE'ler (build sırasında `pnpm fetch-jre` ile indirilir)
# jre = Java 8 (imza/doğrulama), jre21 = Java 21 (XSLT önizleme)
src-tauri/resources/jre/*
!src-tauri/resources/jre/.gitkeep
src-tauri/resources/jre21/*
!src-tauri/resources/jre21/.gitkeep

# Build sırasında `pnpm fetch-services` ile gömülen Java servis jar'ları
# (agent/ verifier/ xslt/). Sürüm DESKTOP UYGULAMASINA kilitlenir; yalnız
# klasör yapısı (.gitkeep) izlenir, jar içeriği ve sürüm kilidi hariç tutulur.
src-tauri/resources/services/*
!src-tauri/resources/services/.gitkeep

# Tauri updater imza anahtarları (GİZLİ — repoya commit'lenmemeli)
src-tauri/.tauri/
*.key
*.key.pub

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
